# 环境变量配置
NODE_ENV=development

# API服务配置
API_PORT=8080
API_KEY_PREFIX=ak-

# MySQL数据库配置
# 需要先安装并启动MySQL服务，创建数据库和用户
# 可以使用Docker快速启动: docker run --name mysql-ai-qa -e MYSQL_ROOT_PASSWORD=password -e MYSQL_DATABASE=ai_qa_comparison -p 3306:3306 -d mysql:8
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=ai_qa_comparison
DB_CONNECTION_LIMIT=10

# 浏览器自动化配置
PUPPETEER_HEADLESS=true
PUPPETEER_TIMEOUT=30000

# 日志配置
LOG_LEVEL=info
LOG_FILE=logs/app.log