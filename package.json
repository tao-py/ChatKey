{
  "name": "ai-qa-comparison-tool",
  "version": "1.0.0",
  "description": "AI问答对比工具 - 同时向多个AI平台提问并对比回答",
  "main": "src/main/main.js",
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:3001 && electron .\"",
    "dev:renderer": "cd src/renderer && cross-env HOST=127.0.0.1 PORT=3001 DANGEROUSLY_DISABLE_HOST_CHECK=true npm start",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "cd src/renderer && npm run build",
    "build:main": "echo 'Main build complete'",
    "pack": "electron-builder",
    "dist": "electron-builder --publish=never",
    "lint": "eslint src/",
    "test": "node test/run-tests.js",
    "test:unit": "jest",
    "api": "node src/api/server.js",
    "debug:browser": "node start-debug-browser.js",
    "check:login": "node check-login.js",
    "init:db": "node init_mysql.js",
    "fix:platforms": "node fix-all-platforms.js"
  },
  "keywords": [
    "electron",
    "ai",
    "qa",
    "comparison",
    "puppeteer"
  ],
  "author": "AI Tool Developer",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^27.3.11",
    "electron-builder": "^24.6.4",
    "eslint": "^8.50.0",
    "eslint-plugin-react": "^7.37.5",
    "jest": "^29.7.0",
    "playwright": "^1.58.2",
    "wait-on": "^7.0.1"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "chrome-remote-interface": "^0.33.3",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "mysql2": "^3.18.2",
    "puppeteer": "^21.3.0",
    "uuid": "^9.0.1"
  },
  "build": {
    "appId": "com.ai.qa.comparison",
    "productName": "AI问答对比工具",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "!node_modules/.cache",
      "!src/renderer/node_modules"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
